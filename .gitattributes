# テキストファイルの改行コードを LF に統一
# Windows 環境でのパス区切り文字の差異（/ vs \）による
# 同一ファイルの重複追跡を防ぐ
* text=auto eol=lf

# 明示的にテキスト扱い
*.js    text eol=lf
*.mjs   text eol=lf
*.json  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.mdc   text eol=lf
*.txt   text eol=lf

# Windows バッチファイル（CRLF 必須）
*.bat   text eol=crlf

# バイナリファイル（改行変換しない）
*.png   binary
*.jpg   binary
*.jpeg  binary
*.ico   binary
*.woff  binary
*.woff2 binary
